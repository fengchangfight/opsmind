# app RAG Demo Configuration
# Copy this to .env and fill in your values

# DeepSeek API Key (for LLM reasoning)
# Get from: https://platform.deepseek.com/
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro

# Embedding (local ONNX via FastEmbed, no API key needed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Milvus Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DIM=384

# Sample Data
SAMPLE_DATA_DIR=./sampledata/all_documents

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Demo: which categories to index (comma-separated, empty=all)
DEMO_CATEGORIES_RAW=confluence,github

# Demo: max documents per category
DEMO_MAX_DOCS_PER_CATEGORY=50

# API
API_HOST=0.0.0.0
API_PORT=8000

# Retrieval
TOP_K=5
