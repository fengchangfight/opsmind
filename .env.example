# OpsMind RAG — Configuration Template
# Copy to .env and fill in your values

# DeepSeek API Key
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro

# Embedding (local ONNX via FastEmbed, no API key needed)
EMBEDDING_DENSE_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_SPARSE_MODEL=Qdrant/bm25

# Milvus Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=opsmind_chunks
MILVUS_DIM=384

# Database (sqlite or postgres)
DB_BACKEND=sqlite
SQLITE_PATH=./data/opsmind.db
POSTGRES_DSN=postgresql://localhost:5432/opsmind

# Sample Data
SAMPLE_DATA_DIR=./sampledata/all_documents

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=32

# Demo: which categories to index (comma-separated, empty=all)
DEMO_CATEGORIES_RAW=confluence,github

# Demo: max documents per category
DEMO_MAX_DOCS_PER_CATEGORY=5

# API
API_HOST=0.0.0.0
API_PORT=8000

# Retrieval
TOP_K=5
